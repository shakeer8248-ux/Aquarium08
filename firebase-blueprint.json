{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An aquarium product, fish, or plant for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "scientificName": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["fish", "plants", "equipment"] },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Intermediate", "Advanced"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "customerEmail": { "type": "string" },
        "customerUid": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerEmail", "customerUid", "items", "total", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all available products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
